{
	"presets": [
		[
			"@babel/preset-env",
			{
				"loose": true
			}
		],
		"@babel/preset-react"
	],
	"plugins": [
		"react-hot-loader/babel",
		[
			"@babel/plugin-proposal-private-methods",
			{
				"loose": true
			}
		],
		[
			"@babel/plugin-proposal-class-properties",
			{
				"loose": true
			}
		]
	]
}